 136          void UART_ISR(void) interrupt 4
 137          {
 138   1        unsigned char rx_data;
 139   1        if (RI == 1)
 140   1        {
 141   2          RI = 0;
 142   2          rx_data = SBUF;
 143   2          rx_raw++;
 144   2      
 145   2          if (rx_data == '$')
 146   2          {
 147   3            rx_dollar++;
 148   3            uart_start = 1;
 149   3            uart_rx_num = 0;
 150   3            uart_rxbuf[uart_rx_num++] = rx_data;
 151   3          }
 152   2          else if (uart_start == 1)
 153   2          {
 154   3            uart_rxbuf[uart_rx_num++] = rx_data;
 155   3            if (rx_data == '#')
 156   3            {
 157   4              rx_hash++;
 158   4              uart_newdata = 1;
 159   4              rx_done++;
 160   4              uart_start = 0;
 161   4            }
 162   3            if (uart_rx_num >= 19)
 163   3            {
 164   4              uart_rx_num = 0;
 165   4              uart_start = 0;
 166   4            }
 167   3          }
 168   2        }
 169   1        if (TI == 1) { TI = 0; }
 170   1      }
