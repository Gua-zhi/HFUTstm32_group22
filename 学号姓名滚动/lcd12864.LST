  95          {
  96   1          LCD_Data = 0xFF;
  97   1          LCD_RS = 0;
  98   1          LCD_RW = 1;
  99   1          LCD_E = 1;
 100   1          Delay5Ms();
 101   1          while (LCD_Data & Busy); //检测忙信号 
 102   1          LCD_E = 0;
 103   1          return(1);
 104   1      }
 105          
 106          /***********初始化********************************************************/
 107          void LCDInit(void)
 108          {
 109   1          WriteCommandLCD(0x30, 1); //先基础模式上电
 110   1          Delay5Ms();
