  81          /***********写指令********************************************************/
  82          void WriteCommandLCD(unsigned char WCLCD, BuysC) //BuysC为0时忽略忙检测
  83          {
  84   1          if (BuysC) ReadStatusLCD(); //根据需要检测忙 
  85   1          LCD_RS = 0;
  86   1          LCD_RW = 0;
  87   1          LCD_Data = WCLCD;
  88   1          LCD_E = 1;
