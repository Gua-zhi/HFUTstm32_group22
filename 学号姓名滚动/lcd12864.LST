 129          /***********按指定位置显示一个字符*******************************************/
 130          void DisplayOneChar(unsigned char X, unsigned char Y, unsigned char DData)
 131          {
 132   1          unsigned char addr;
 133   1          //只允许第1行输出
 134   1          if (Y != 1)
 135   1              return;
 136   1      
 137   1          X &= 0x0F;  //限制列0~15
 138   1          addr = 0x80 + X; //第一行固定基地址
 139   1      
 140   1          WriteCommandLCD(addr, 0);
 141   1          WriteDataLCD(DData);
 142   1      }
 143          
 144          /***********文字滚动函数*****************************************/
 145          void ScrollText(unsigned char* show_str)
 146          {
 147   1          unsigned char i, str_len;
 148   1          str_len = 0;
 149   1          while (show_str[str_len] != '\0') str_len++;
 150   1      
 151   1          LCDClear();
 152   1          for (i = 0; i < str_len && i < 16; i++)
 153   1          {
 154   2              DisplayOneChar(i, 1, show_str[i]);
 155   2          }
 156   1          Delay400Ms();
 157   1          Delay400Ms();
 158   1          Delay400Ms();
 159   1          Delay400Ms();
 160   1      }
