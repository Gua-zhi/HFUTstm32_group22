  69          /***********写数据********************************************************/
  70          void WriteDataLCD(unsigned char WDLCD)
  71          {
  72   1          ReadStatusLCD(); //检测忙 
  73   1          LCD_RS = 1;
  74   1          LCD_RW = 0;
  75   1          LCD_Data = WDLCD;
