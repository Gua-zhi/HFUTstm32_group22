  97   4            }
  98   3            while(key3 == 0);
  99   3            delay(10);
 100   3            AllLedOff();
 101   3            P0 = 0xC0;
 102   3          }
 103   2          else if(key4 == 0)
 104   2          {
 105   3            delay(10);
 106   3            if(key4 == 0)
 107   3            {
 108   4              AllLedOff();
 109   4              led4 = 0;    // 4号灯亮
