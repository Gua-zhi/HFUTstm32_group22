 111   4            }
 112   3            while(key4 == 0);
 113   3            delay(10);
 114   3            AllLedOff();
 115   3            P0 = 0xC0;
 116   3          }
 117   2          else if(key5 == 0)
C51 COMPILER V9.60.7.0   L_KEY                                                             06/18/2026 15:08:20 PAGE 3   

 118   2          {
 119   3            delay(10);
